  "info": {
    "_postman_id": "cc487b72-3872-47d7-a27e-21e6dbdd690f",
    "description": "Coleção para demonstrar os principais endpoints REST do sistema PESCD. Use o environment `PESCD Local` e execute os logins por perfil antes das rotas protegidas. A autenticação é por sessão/cookie do Spring Security.",
    "name": "PESCD API - Demonstração",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "item": [
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Resposta 200', function () { pm.response.to.have.status(200); });",
                  "const ofertas = pm.response.json();",
                  "if (Array.isArray(ofertas) && ofertas.length > 0) {",
                  "  pm.environment.set('ofertaId', ofertas[0].id);",
                  "  pm.collectionVariables.set('ofertaId', ofertas[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "name": "Listar ofertas públicas",
