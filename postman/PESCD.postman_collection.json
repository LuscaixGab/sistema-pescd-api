            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/professor-responsavel/ofertas/{{ofertaResponsavelId}}/encerramento",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "professor-responsavel",
                "ofertas",
                "{{ofertaResponsavelId}}",
                "encerramento"
              ]
            }
          }
        },
        {
          "name": "Listar documentações pendentes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/professor-responsavel/documentacoes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "professor-responsavel",
                "documentacoes"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const itens = pm.response.json();",
                  "  if (Array.isArray(itens) && itens.length > 0) {",
