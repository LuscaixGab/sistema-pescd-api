    {
      "name": "06 - Professor Responsável",
      "description": "Execute `Login Professor` antes destes requests. As análises exigem IDs de inscrições que estejam em fase compatível.",
      "item": [
        {
          "name": "Listar ofertas do responsável",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/professor-responsavel/ofertas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "professor-responsavel",
                "ofertas"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const ofertas = pm.response.json();",
                  "  if (Array.isArray(ofertas) && ofertas.length > 0) {",
                  "    const encerravel = ofertas.find(o => o.podeEncerrar) || ofertas[0];",
                  "    pm.environment.set('ofertaResponsavelId', encerravel.id);",
                  "    pm.collectionVariables.set('ofertaResponsavelId', encerravel.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
