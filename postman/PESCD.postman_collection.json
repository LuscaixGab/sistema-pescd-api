    {
      "description": "Execute `Login Aluno`. Para uploads, selecione um PDF nos campos de tipo File. Alguns requests precisam de `inscricaoId`; se a listagem de ofertas do aluno estiver bloqueada, preencha manualmente a variável com um UUID de inscrição existente no banco.",
      "item": [
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const inscricoes = pm.response.json();",
                  "  const naoEnviado = inscricoes.find(i => i.status === 'NAO_ENVIADO');",
                  "  const planoAprovado = inscricoes.find(i => i.status === 'PLANO_APROVADO');",
                  "  if (naoEnviado) {",
                  "    pm.environment.set('inscricaoId', naoEnviado.id);",
                  "    pm.collectionVariables.set('inscricaoId', naoEnviado.id);",
                  "  }",
                  "  if (planoAprovado) {",
                  "    pm.environment.set('inscricaoPlanoAprovadoId', planoAprovado.id);",
                  "    pm.collectionVariables.set('inscricaoPlanoAprovadoId', planoAprovado.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
